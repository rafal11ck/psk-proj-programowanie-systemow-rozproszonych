{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "PasswordBreak": {
    "AttackMode": "bruteforce",
    "CharSet": "abcdefghijklmnopqrstuvwxyz0123456789",
    "MinLength": 1,
    "MaxLength": 4,
    "ChunkSize": 1000,
    "WordListPath": "wordlist.txt",
    "HeartbeatTimeoutSeconds": 60
  }
}